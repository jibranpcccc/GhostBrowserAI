# Cloudflare AI Gateway Configuration (Mandatory)
# The system strictly forces all AI generation to pass through this Cloudflare route.
CLOUDFLARE_ACCOUNT_ID="YOUR_CF_ACCOUNT_ID"
CLOUDFLARE_GATEWAY="browser-ai-gateway"
KIMI_API_TOKEN="sk-your-kimi-token"

# Optional: The model name to use. Defaults to "moonshot-v1-8k"
KIMI_MODEL_NAME="moonshot-v1-8k"
